@page "/"
@using Microsoft.AspNetCore.SignalR.Client
@using BookGrid.Models
@using BookGrid.Services
@inject RoomService RoomService
@inject LibCalService LibCalService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<div id="app">
    <img src="/URI_11-16_21-3.jpg" alt="Library Header" class="header-image" />
    <h1>Reserve a Study Room at the Carothers Library</h1>

    <div class="header">
        <p>Viewing: @FormatDate(selectedDate)</p>
        <div>
            @if (IsToday)
            {
                <button @onclick="GoToTomorrow">Tomorrow</button>
            }
            else
            {
                <button @onclick="GoToToday">Today</button>
            }
        </div>
    </div>

    <nav class="filters">
        <label>
            Floor
            <select @bind="selectedZone">
                @foreach (var zone in zones)
                {
                    <option value="@zone">@zone</option>
                }
            </select>
        </label>
        <label>
            Room
            <select @bind="selectedRoomName">
                @foreach (var roomName in roomNames)
                {
                    <option value="@roomName">@roomName</option>
                }
            </select>
        </label>
        <label>
            Capacity
            <select @bind="selectedCapacity">
                <option value="All">All</option>
                @foreach (var capacity in capacities)
                {
                    <option value="@capacity">@capacity</option>
                }
            </select>
        </label>
    </nav>

    @if (loading)
    {
        <div>Loading...</div>
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <div>@error</div>
    }
    else
    {
        <div class="rooms">
            @if (filteredSortedRooms?.Count == 0)
            {
                <div class="no-rooms">No rooms available for this date.</div>
            }
            else if (filteredSortedRooms != null)
            {
                @foreach (var room in filteredSortedRooms)
                {
                    <div class="room-card @(expandedRooms.Contains(room.Id) ? "expanded" : "")" @onclick="() => ToggleExpanded(room.Id)">
                        @if (IsRoomAvailableNow(room))
                        {
                            <div class="availability-pill">Available Now</div>
                        }
                        
                        <h3>@room.Name@(expandedRooms.Contains(room.Id) ? $" - {room.Zone}" : "")</h3>
                        <div class="room-meta">Capacity: <strong>@(room.Capacity?.ToString() ?? "Unknown")</strong></div>
                        
                        @if (expandedRooms.Contains(room.Id))
                        {
                            <img src="/facade.jpg" alt="Library Facade" class="modal-facade" @onclick:stopPropagation="true" />
                        }
                        
                        <div class="timeline" style="position: relative; height: 24px;">
                            <div class="time-label" style="left: 0%;">@FormatTimeLabel("start")</div>
                            <div class="time-label" style="left: 50%;">@FormatTimeLabel("middle")</div>
                            <div class="time-label" style="right: 0%;">@FormatTimeLabel("end")</div>
                            
                            @if (!string.IsNullOrEmpty(hoverTime) && expandedRooms.Contains(room.Id))
                            {
                                <div class="hover-tooltip" style="left: @(hoverLeft)px;">@hoverTime</div>
                            }
                            
                            @if (selectedTimes.ContainsKey(room.Id) && expandedRooms.Contains(room.Id))
                            {
                                <div class="selected-booking" style="@GetSelectedBookingStyle(room.Id)">
                                    @duration min
                                </div>
                            }
                            
                            @foreach (var segment in GetTimelineSegments(room))
                            {
                                <div class="booking-segment" style="@GetBookingStyle(segment)" title="@($"{FormatTime(segment.From)} - {FormatTime(segment.To)}")"></div>
                            }
                        </div>
                        
                        @if (expandedRooms.Contains(room.Id))
                        {
                            <div class="time-selectors">
                                <label>Start Time:
                                    <select value="@GetSelectedStart(room.Id)" @onchange="@((e) => SetSelectedStart(room.Id, e.Value?.ToString() ?? ""))" @onchange:after="() => UpdateSelection(room.Id)">
                                        <option value="">Select Start</option>
                                        @foreach (var time in timeOptions)
                                        {
                                            <option value="@time">@time</option>
                                        }
                                    </select>
                                </label>
                                <label>End Time:
                                    <select value="@GetSelectedEnd(room.Id)" @onchange="@((e) => SetSelectedEnd(room.Id, e.Value?.ToString() ?? ""))" @onchange:after="() => UpdateSelection(room.Id)">
                                        <option value="">Select End</option>
                                        @foreach (var time in timeOptions)
                                        {
                                            <option value="@time">@time</option>
                                        }
                                    </select>
                                </label>
                            </div>
                        }
                        
                        @if (expandedRooms.Contains(room.Id) && selectedTimes.ContainsKey(room.Id))
                        {
                            <form @onsubmit="(e) => BookRoom(room, e)" @onsubmit:preventDefault="true" @onclick:stopPropagation="true" class="booking-form">
                                <h4>Book this room from @FormatTime(MinutesToTime(selectedTimes[room.Id])) to @FormatTime(MinutesToTime(selectedTimes[room.Id] + duration))</h4>
                                <p>Drag the grey bar on the timeline to adjust duration (30 min - 3 hours)</p>
                                <input @bind="fname" type="text" placeholder="First Name" required />
                                <input @bind="lname" type="text" placeholder="Last Name" required />
                                <input @bind="email" type="email" placeholder="URI.edu Email" required pattern=".*@@uri\.edu$$" />
                                <button type="submit">Book Now</button>
                            </form>
                        }
                    </div>
                }
            }
        </div>
    }

    @if (expandedRooms.Any())
    {
        <div class="backdrop" @onclick="() => expandedRooms.Clear()"></div>
    }
</div>

@code {
    private HubConnection? hubConnection;
    private List<Room> rooms = new();
    private HashSet<int> expandedRooms = new();
    private bool loading = true;
    private string? error;
    
    // Filter properties
    private DateTime selectedDate = DateTime.Today;
    private string selectedZone = "All";
    private string selectedRoomName = "All";
    private string selectedCapacity = "All";

    // Form data
    private string fname = "";
    private string lname = "";
    private string email = "";
    
    // Interactive selection
    private Dictionary<int, int> selectedTimes = new();
    private Dictionary<int, string> selectedStarts = new();
    private Dictionary<int, string> selectedEnds = new();
    private int duration = 60;
    private string? hoverTime;
    private int hoverLeft = 0;

    // Computed properties
    private bool IsToday => selectedDate.Date == DateTime.Today;
    
    private List<string> zones => new() { "All", "Lower Level", "First Floor", "Second Floor", "Third Floor" };
    
    private List<string> roomNames
    {
        get
        {
            var list = rooms.Where(r => selectedZone == "All" || r.Zone == selectedZone);
            var names = list.Select(r => r.Name).Distinct().OrderBy(n => n, StringComparer.OrdinalIgnoreCase).ToList();
            names.Insert(0, "All");
            return names;
        }
    }
    
    private List<int> capacities
    {
        get
        {
            var expectedCapacities = new[] { 1, 2, 4 };
            var nums = rooms.Select(r => r.Capacity).Where(c => c.HasValue).Select(c => c!.Value).ToHashSet();
            var filtered = nums.Where(expectedCapacities.Contains).OrderBy(x => x).ToList();
            return filtered.Any() ? filtered : expectedCapacities.ToList();
        }
    }
    
    // Helper methods to safely access dictionaries
    private string GetSelectedStart(int roomId)
    {
        if (!selectedStarts.ContainsKey(roomId))
            selectedStarts[roomId] = string.Empty;
        return selectedStarts[roomId];
    }
    
    private void SetSelectedStart(int roomId, string value)
    {
        selectedStarts[roomId] = value;
    }
    
    private string GetSelectedEnd(int roomId)
    {
        if (!selectedEnds.ContainsKey(roomId))
            selectedEnds[roomId] = string.Empty;
        return selectedEnds[roomId];
    }
    
    private void SetSelectedEnd(int roomId, string value)
    {
        selectedEnds[roomId] = value;
    }
    
    private List<Room>? filteredSortedRooms
    {
        get
        {
            var filtered = rooms.Where(r =>
            {
                if (selectedZone != "All" && r.Zone != selectedZone) return false;
                if (selectedRoomName != "All" && r.Name != selectedRoomName) return false;
                if (selectedCapacity != "All")
                {
                    if (int.TryParse(selectedCapacity, out int minCap))
                    {
                        if (!r.Capacity.HasValue || r.Capacity.Value < minCap) return false;
                    }
                }
                return true;
            }).ToList();
            
            return filtered.OrderByDescending(r => GetAvailabilityPercent(r.Id))
                          .ThenBy(r => r.Name, StringComparer.OrdinalIgnoreCase)
                          .ThenBy(r => r.Id)
                          .ToList();
        }
    }
    
    private List<string> timeOptions
    {
        get
        {
            var options = new List<string>();
            for (int i = 0; i < 32; i++)
            {
                var hour = 8 + i / 2;
                var min = (i % 2) * 30;
                var displayHour = hour % 12;
                if (displayHour == 0) displayHour = 12;
                var ampm = hour >= 12 ? "PM" : "AM";
                options.Add($"{displayHour}:{min:D2} {ampm}");
            }
            return options;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRoomsAsync();
        loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await InitializeSignalR();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"SignalR initialization failed: {ex.Message}");
            }
        }
    }

    private async Task InitializeSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/bookingHub"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<int>("BookingUpdated", async (roomId) =>
            {
                await InvokeAsync(async () =>
                {
                    await RefreshSingleRoom(roomId);
                    StateHasChanged();
                });
            });

            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR connection failed: {ex.Message}");
        }
    }

    private async Task LoadRoomsAsync()
    {
        try
        {
            loading = true;
            error = null;
            
            var filter = new RoomFilter
            {
                Zone = selectedZone,
                Capacity = selectedCapacity,
                SelectedDate = selectedDate
            };
            
            rooms = await RoomService.GetFilteredRoomsAsync(filter);
            
            // Initialize dictionaries for all rooms
            foreach (var room in rooms)
            {
                if (!selectedStarts.ContainsKey(room.Id))
                    selectedStarts[room.Id] = string.Empty;
                if (!selectedEnds.ContainsKey(room.Id))
                    selectedEnds[room.Id] = string.Empty;
            }
        }
        catch (Exception ex)
        {
            error = $"Failed to load rooms: {ex.Message}";
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private string FormatDate(DateTime date) => date.ToString("M/d/yyyy");
    
    private void GoToTomorrow()
    {
        selectedDate = selectedDate.AddDays(1);
        InvokeAsync(LoadRoomsAsync);
    }
    
    private void GoToToday()
    {
        selectedDate = DateTime.Today;
        InvokeAsync(LoadRoomsAsync);
    }
    
    private void ToggleExpanded(int roomId)
    {
        if (expandedRooms.Contains(roomId))
        {
            expandedRooms.Remove(roomId);
            selectedTimes.Remove(roomId);
            selectedStarts.Remove(roomId);
            selectedEnds.Remove(roomId);
        }
        else
        {
            expandedRooms.Add(roomId);
        }
        StateHasChanged();
    }
    
    private bool IsRoomAvailableNow(Room room)
    {
        return room.Availability?.Any() == true;
    }
    
    private string FormatTimeLabel(string position)
    {
        return position switch
        {
            "start" => "8:00 AM",
            "middle" => "3:30 PM",
            "end" => "11:00 PM",
            _ => ""
        };
    }
    
    private string GetSelectedBookingStyle(int roomId)
    {
        if (!selectedTimes.ContainsKey(roomId)) return "display: none;";
        
        var startMinutes = selectedTimes[roomId];
        var openStart = 8 * 60;
        var openEnd = 23 * 60;
        var totalMinutes = openEnd - openStart;
        var left = ((startMinutes - openStart) / (double)totalMinutes) * 100;
        var width = (duration / (double)totalMinutes) * 100;
        
        return $"left: {left:F1}%; width: {width:F1}%;";
    }
    
    private List<TimelineSegment> GetTimelineSegments(Room room)
    {
        if (room.Availability == null || !room.Availability.Any())
        {
            return new List<TimelineSegment>();
        }
        
        return room.Availability.Select(a => new TimelineSegment 
        { 
            From = a.From, 
            To = a.To, 
            IsApiAvailability = false 
        }).ToList();
    }
    
    private string GetBookingStyle(TimelineSegment segment)
    {
        var openStart = 8 * 60;
        var openEnd = 23 * 60;
        var totalMinutes = openEnd - openStart;
        
        var startMinutes = ParseTimeToMinutes(segment.From);
        var endMinutes = ParseTimeToMinutes(segment.To);
        
        var adjStart = Math.Max(startMinutes, openStart);
        var adjEnd = Math.Min(endMinutes, openEnd);
        
        if (adjStart >= adjEnd) return "display: none;";
        
        var left = ((adjStart - openStart) / (double)totalMinutes) * 100;
        var width = ((adjEnd - adjStart) / (double)totalMinutes) * 100;
        var background = segment.IsApiAvailability ? "#e74c3c" : "#27ae60";
        
        return $"position: absolute; left: {left:F1}%; width: {width:F1}%; background: {background}; border-radius: 4px; height: 100%;";
    }
    
    private int ParseTimeToMinutes(DateTime dateTime)
    {
        return dateTime.Hour * 60 + dateTime.Minute;
    }
    
    private string FormatTime(DateTime dateTime)
    {
        var hour = dateTime.Hour % 12;
        if (hour == 0) hour = 12;
        var ampm = dateTime.Hour >= 12 ? "PM" : "AM";
        return $"{hour}:{dateTime.Minute:D2} {ampm}";
    }
    
    private DateTime MinutesToTime(int minutes)
    {
        return selectedDate.AddMinutes(minutes);
    }
    
    private void UpdateSelection(int roomId)
    {
        if (selectedStarts.ContainsKey(roomId) && selectedEnds.ContainsKey(roomId))
        {
            var start = selectedStarts[roomId];
            var end = selectedEnds[roomId];
            
            if (!string.IsNullOrEmpty(start) && !string.IsNullOrEmpty(end))
            {
                var startMinutes = ParseTimeStringToMinutes(start);
                var endMinutes = ParseTimeStringToMinutes(end);
                
                if (endMinutes > startMinutes)
                {
                    selectedTimes[roomId] = startMinutes;
                    duration = endMinutes - startMinutes;
                    StateHasChanged();
                }
            }
        }
    }
    
    private int ParseTimeStringToMinutes(string timeString)
    {
        var parts = timeString.Split(' ');
        var timePart = parts[0].Split(':');
        var hour = int.Parse(timePart[0]);
        var minute = int.Parse(timePart[1]);
        var ampm = parts[1];
        
        if (ampm == "PM" && hour != 12) hour += 12;
        if (ampm == "AM" && hour == 12) hour = 0;
        
        return hour * 60 + minute;
    }
    
    private async Task BookRoom(Room room, EventArgs e)
    {
        try
        {
            var request = new BookingRequest
            {
                RoomId = room.Id,
                StartTime = MinutesToTime(selectedTimes[room.Id]),
                EndTime = MinutesToTime(selectedTimes[room.Id] + duration),
                FirstName = fname,
                LastName = lname,
                Email = email
            };
            
            var result = await LibCalService.CreateBookingAsync(request);
            if (result.Success)
            {
                fname = "";
                lname = "";
                email = "";
                selectedTimes.Remove(room.Id);
                selectedStarts.Remove(room.Id);
                selectedEnds.Remove(room.Id);
                duration = 60;
                
                await LoadRoomsAsync();
                await JS.InvokeVoidAsync("alert", "Booking successful!");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Booking failed: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Booking error: {ex.Message}");
        }
    }
    
    private double GetAvailabilityPercent(int roomId)
    {
        var room = rooms.FirstOrDefault(r => r.Id == roomId);
        if (room?.Availability == null || !room.Availability.Any())
            return 0.0;
        
        var totalAvailableMinutes = room.Availability.Sum(a => 
        {
            var start = ParseTimeToMinutes(a.From);
            var end = ParseTimeToMinutes(a.To);
            return end - start;
        });
        
        var totalDayMinutes = 15 * 60;
        return (double)totalAvailableMinutes / totalDayMinutes;
    }

    private async Task RefreshSingleRoom(int roomId)
    {
        try
        {
            await LoadRoomsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to refresh room {roomId}: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
    
    public class TimelineSegment
    {
        public DateTime From { get; set; }
        public DateTime To { get; set; }
        public bool IsApiAvailability { get; set; }
    }
}